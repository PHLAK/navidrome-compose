# ------------------------------------------------------------------------------
# Navidrome version override. Update this value and restart your containers
# (i.e. 'docker compose up -d') to update your installation.
# ------------------------------------------------------------------------------

# NAVIDROME_VERSION=latest

# ------------------------------------------------------------------------------
# The Navidrome server port to be exposed to the host.
# ------------------------------------------------------------------------------

# NAVIDROME_PORT=4533

# ------------------------------------------------------------------------------
# Path to the Navidrome data directories. These paths may be absolute or relative
# to the 'docker-compose.yaml' file.
# ------------------------------------------------------------------------------

# NAVIDROME_DATA_PATH=./data

# ------------------------------------------------------------------------------
# Path to your top-level music directory. This path can be absolute or relative
# to the 'docker-compose.yaml' file.
# ------------------------------------------------------------------------------

MUSIC_PATH=

# ------------------------------------------------------------------------------
# Host process user and group IDs. Setting these will map the host user/group
# to the user/group running within the container. This helps avoid permission
# issues between your host machine and docker container.
# ------------------------------------------------------------------------------

# HOST_USER_ID=
# HOST_GROUP_ID=
